# Footballive90 Landing Site — copy to .env and run: node scripts/generate-config.js
# Generated output: js/site-config.js (loaded by all pages)

# API
SITE_API_BASE_URL=https://mallmanbackend.footballive90.com/api

# Download / app links (leave empty to hide button)
SITE_ANDROID_URL=
SITE_IOS_URL=
SITE_PWA_URL=https://footballive90.com
SITE_APP_URL=https://footballive90.com

# Contact & social
SITE_CONTACT_EMAIL=support@footballive90.com
SITE_CONTACT_PHONE=
SITE_CONTACT_ADDRESS=
SITE_CONTACT_ADDRESS_FA=
SITE_WHATSAPP_URL=
SITE_INSTAGRAM_URL=
SITE_TELEGRAM_URL=
SITE_TWITTER_URL=

# Branding
SITE_FAVICON_URL=icons/favicon.png
SITE_COPYRIGHT_YEAR=2026
